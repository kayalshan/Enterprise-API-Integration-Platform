{
  "info": {
    "name": "Enterprise Core API Service",
    "description": "Postman collection for the core order ingestion API exposed by the Enterprise API and Event-Driven Integration Platform.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
