  "item": [
    {
      "name": "Create Order",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"orderId\": \"ORD-1001\",\n  \"partnerId\": \"partner-sandbox\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/v1/orders",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "v1",
            "orders"
          ]
        },
        "description": "Accept an order for downstream asynchronous orchestration."
      },
