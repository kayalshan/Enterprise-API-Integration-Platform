          "body": "{\n  \"orderId\": \"ORD-1001\",\n  \"partnerId\": \"partner-sandbox\",\n  \"integrationStatus\": \"ACCEPTED\",\n  \"correlationId\": \"5f0c6a4b-d7a1-4f16-9bf1-a6c81293f2bc\",\n  \"acceptedAt\": \"2026-04-04T12:00:00Z\",\n  \"nextStep\": \"Order accepted for downstream event orchestration\"\n}"
